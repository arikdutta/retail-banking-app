{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Retail Banking",
  "version": "0.1.0",
  "identifier": "com.retail-banking.app",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "Retail Banking",
        "width": 1280,
        "height": 800,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "iOS": {
      "developmentTeam": "${APPLE_TEAM_ID}"
    }
  }
}
