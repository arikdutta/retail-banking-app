# Local dev config. POSTGRES_* intentionally duplicated in root .env (docker-compose).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DATABASE=retail_banking_app

# * DON'T CHANGE THIS NAME FOR SQLx TO WORK
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@127.0.0.1/${POSTGRES_DATABASE}

JWT_SECRET=dev-secret-change-in-production