{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT t.unid, t.account_unid, t.description, t.category,\n                   t.amount, t.currency, t.status, t.created_at\n            FROM transactions t\n            JOIN accounts a ON t.account_unid = a.unid\n            WHERE a.user_unid = $1\n            ORDER BY t.created_at DESC\n            LIMIT $2\n            ",
