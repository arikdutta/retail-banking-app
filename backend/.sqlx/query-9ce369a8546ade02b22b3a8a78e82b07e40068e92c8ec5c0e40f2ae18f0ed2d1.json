  "db_name": "PostgreSQL",
  "query": "\n            UPDATE invoices\n            SET status = $3, updated_at = now()\n            WHERE unid = $1 AND user_unid = $2\n            RETURNING unid, user_unid, invoice_number,\n                      recipient_name, recipient_email, recipient_iban,\n                      description,\n                      amount, currency,\n                      status AS \"status: _\",\n                      due_date, notes,\n                      created_at, updated_at\n            ",
