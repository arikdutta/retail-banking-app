@base = http://localhost:3001

# ─────────────────────────────────────────
# HEALTH
# ─────────────────────────────────────────

### Health check
GET {{base}}/health

# ─────────────────────────────────────────
# AUTH (public)
# ─────────────────────────────────────────

### Login
POST {{base}}/api/auth/login
Content-Type: application/json

{
  "email": "user@example.com",
  "password": "password"
}

### Logout
POST {{base}}/api/auth/logout

# ─────────────────────────────────────────
# AUTH (protected)
# ─────────────────────────────────────────

### Me (current user)
GET {{base}}/api/auth/me

# ─────────────────────────────────────────
# DASHBOARD (protected)
# ─────────────────────────────────────────

### Stats
GET {{base}}/api/dashboard/stats

### Users list
GET {{base}}/api/dashboard/users

### Money flow (income vs expenses per day)
GET {{base}}/api/dashboard/money-flow

### Spending breakdown (donut chart)
GET {{base}}/api/dashboard/donut-stats

# ─────────────────────────────────────────
# ROLE ACCESSES (protected)
# ─────────────────────────────────────────

### All role accesses
GET {{base}}/api/roleaccesses

### My roles
GET {{base}}/api/roleaccesses/mine

### Root check
GET {{base}}/api/roleaccesses/root-check

# ─────────────────────────────────────────
# BUG REPORTS (public: POST | protected: GET/DELETE)
# ─────────────────────────────────────────

### Create bug report (public)
POST {{base}}/api/bugreports
Content-Type: application/json

{
  "bug_type": "Bug",
  "message": "Uncaught TypeError: Cannot read properties of undefined",
  "exception_message": "TypeError: Cannot read properties of undefined (reading 'id')",
  "stack_trace": "at Component.render (app.js:42)\n  at updateTree (react-dom.js:100)",
  "user_login": "root@example.com",
  "url": "http://localhost:3000/dashboard",
  "user_agent": "Mozilla/5.0",
  "application": "frontend"
}

### List bug reports (protected)
GET {{base}}/api/bugreports

### List bug reports — paginated + filtered
GET {{base}}/api/bugreports?page=1&per_page=20&bug_type=Bug

### List bug reports — search
GET {{base}}/api/bugreports?search=TypeError

### Get single bug report (protected)
GET {{base}}/api/bugreports/{{unid}}

### Charts (protected)
GET {{base}}/api/bugreports/charts

### Delete all bug reports (protected)
DELETE {{base}}/api/bugreports

# ─────────────────────────────────────────
# ACCOUNTS (protected)
# ─────────────────────────────────────────

### List accounts for current user
GET {{base}}/api/accounts

### Get single account
# Replace the UUID with one from the seed data or a real account unid
GET {{base}}/api/accounts/a0b1c2d3-e4f5-6789-abcd-ef0123456789

# ─────────────────────────────────────────
# TRANSACTIONS (protected)
# ─────────────────────────────────────────

### List transactions — first page, 20 per page
GET {{base}}/api/transactions

### List transactions — paginated
GET {{base}}/api/transactions?page=2&per_page=10

### List transactions — filtered by account
GET {{base}}/api/transactions?account_unid=a0b1c2d3-e4f5-6789-abcd-ef0123456789

### List transactions — filtered by account, paginated
GET {{base}}/api/transactions?account_unid=a0b1c2d3-e4f5-6789-abcd-ef0123456789&page=1&per_page=5

### Recent activity feed (last 20 by default)
GET {{base}}/api/transactions/activity

### Recent activity feed — custom limit
GET {{base}}/api/transactions/activity?limit=5

# ─────────────────────────────────────────
# SAVINGS GOALS (protected)
# ─────────────────────────────────────────

### List savings goals for current user
GET {{base}}/api/savings
